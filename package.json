{
  "name": "@open-core/fivem-adapter",
  "version": "1.0.3",
  "description": "External FiveM adapter for OpenCore framework.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "check": "pnpm typecheck && pnpx @biomejs/biome check --write"
  },
  "keywords": [
    "opencore",
    "fivem",
    "adapter",
    "citizenfx"
  ],
  "license": "MPL-2.0",
  "packageManager": "pnpm@10.13.1",
  "peerDependencies": {
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@citizenfx/client": "2.0.27366-1",
    "@citizenfx/server": "2.0.27366-1",
    "@open-core/framework": "latest",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "biome": "^0.3.3"
  }
}
