{
  "name": "@open-core/fivem-adapter",
  "version": "0.1.0",
  "description": "External FiveM adapter for OpenCore framework.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {"types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.js"},
    "./server": {"types": "./dist/server/index.d.ts", "import": "./dist/server/index.js", "require": "./dist/server/index.js"},
    "./client": {"types": "./dist/client/index.d.ts", "import": "./dist/client/index.js", "require": "./dist/client/index.js"},
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "check": "pnpm typecheck"
  },
  "keywords": ["opencore", "fivem", "adapter", "citizenfx"],
  "license": "MPL-2.0",
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "@open-core/framework": "file:../opencore-framework"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@citizenfx/client": "2.0.22443-1",
    "@citizenfx/server": "2.0.22443-1",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
